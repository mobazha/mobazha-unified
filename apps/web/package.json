    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "eslint-config-next": "^14.2.0",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.0",
