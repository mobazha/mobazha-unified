{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@mobazha/ui": ["../../packages/ui/index.ts"],
      "@mobazha/ui/*": ["../../packages/ui/*"],
      "@mobazha/core": ["../../packages/core/index.ts"],
      "@mobazha/core/*": ["../../packages/core/*"],
      "@mobazha/commerce-kit": ["../../packages/commerce-kit/src/index.ts"],
      "@mobazha/commerce-kit/cart": ["../../packages/commerce-kit/src/cart/index.tsx"],
      "@mobazha/commerce-kit/product": ["../../packages/commerce-kit/src/product/index.tsx"],
      "@mobazha/commerce-kit/*": [
        "../../packages/commerce-kit/src/*/index.ts",
        "../../packages/commerce-kit/src/*"
      ]
    },
    "target": "ES2017"
  },
  "include": [
    "next-env.d.ts",
    "../../packages/core/types/window.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
