## 四、桌面端特有功能

### 4.1 右键菜单（Context Menu）

```tsx
import {
  ContextMenu,
  ContextMenuContent,
  ContextMenuItem,
  ContextMenuTrigger,
} from '@/components/ui/context-menu';

<ContextMenu>
  <ContextMenuTrigger>
    <ProductCard />
  </ContextMenuTrigger>
  <ContextMenuContent>
    <ContextMenuItem onClick={handleEdit}>编辑</ContextMenuItem>
    <ContextMenuItem onClick={handleDelete}>删除</ContextMenuItem>
    <ContextMenuItem onClick={handleShare}>分享</ContextMenuItem>
  </ContextMenuContent>
</ContextMenu>
```

### 4.2 拖拽排序

```tsx
// 使用 @dnd-kit 或类似库
import { DndContext, closestCenter } from '@dnd-kit/core';
import { SortableContext, verticalListSortingStrategy } from '@dnd-kit/sortable';

<DndContext collisionDetection={closestCenter} onDragEnd={handleDragEnd}>
  <SortableContext items={items} strategy={verticalListSortingStrategy}>
    {items.map(item => <SortableItem key={item.id} {...item} />)}
  </SortableContext>
</DndContext>
```

### 4.3 批量操作

```tsx
// 多选模式
const [selectedIds, setSelectedIds] = useState<Set<string>>(new Set());

<div className="flex items-center gap-2 mb-4">
  <Checkbox 
    checked={selectedIds.size === items.length}
    onCheckedChange={handleSelectAll}
  />
  <span>全选</span>
  {selectedIds.size > 0 && (
    <>
      <Button variant="outline" size="sm" onClick={handleBatchDelete}>
        删除 ({selectedIds.size})
      </Button>
      <Button variant="outline" size="sm" onClick={handleBatchExport}>
        导出
      </Button>
    </>
  )}
</div>
```

### 4.4 快捷键

```tsx
import { useHotkeys } from 'react-hotkeys-hook';

// 全局快捷键
useHotkeys('ctrl+k, cmd+k', () => openSearch(), { preventDefault: true });
useHotkeys('ctrl+n, cmd+n', () => createNew(), { preventDefault: true });
useHotkeys('escape', () => closeModal());

// 显示快捷键提示
<Tooltip>
  <TooltipTrigger>
    <Button>搜索</Button>
  </TooltipTrigger>
  <TooltipContent>
    搜索 <kbd className="ml-2 px-1 bg-muted rounded text-xs">⌘K</kbd>
  </TooltipContent>
</Tooltip>
```

### 4.5 工具提示（Tooltip）

```tsx
import {
  Tooltip,
  TooltipContent,
  TooltipProvider,
  TooltipTrigger,
} from '@/components/ui/tooltip';

<TooltipProvider>
  <Tooltip>
    <TooltipTrigger asChild>
      <Button variant="ghost" size="icon">
        <Settings className="w-4 h-4" />
      </Button>
    </TooltipTrigger>
    <TooltipContent>
      <p>设置</p>
    </TooltipContent>
  </Tooltip>
</TooltipProvider>
```

### 4.6 自定义滚动条

```css
/* 已在 globals.css 中定义 */
@media (min-width: 768px) {
  ::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }
  ::-webkit-scrollbar-track {
    background: transparent;
  }
  ::-webkit-scrollbar-thumb {
    background: var(--theme-border);
    border-radius: 4px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: var(--theme-textMuted);
  }
}
```

