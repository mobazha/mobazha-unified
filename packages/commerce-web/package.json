{
  "name": "@mobazha/commerce-web",
  "version": "0.1.0",
  "description": "Stable frontend feature contracts shared by Mobazha commerce applications",
  "license": "MPL-2.0",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./storefront": {
      "types": "./dist/storefront/index.d.ts",
      "import": "./dist/storefront/index.mjs",
      "require": "./dist/storefront/index.js"
    },
    "./product": {
      "types": "./dist/product/index.d.ts",
      "import": "./dist/product/index.mjs",
      "require": "./dist/product/index.js"
    },
    "./cart": {
      "types": "./dist/cart/index.d.ts",
      "import": "./dist/cart/index.mjs",
      "require": "./dist/cart/index.js"
    },
    "./checkout": {
      "types": "./dist/checkout/index.d.ts",
      "import": "./dist/checkout/index.mjs",
      "require": "./dist/checkout/index.js"
    },
    "./admin": {
      "types": "./dist/admin/index.d.ts",
      "import": "./dist/admin/index.mjs",
      "require": "./dist/admin/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "test:unit": "vitest run"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  },
  "peerDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "publishConfig": {
    "access": "public"
  }
}
