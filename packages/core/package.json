{
  "name": "@mobazha/core",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./services/*": {
      "import": "./dist/services/*.mjs",
      "require": "./dist/services/*.js",
      "types": "./dist/services/*.d.ts"
    },
    "./stores/*": {
      "import": "./dist/stores/*.mjs",
      "require": "./dist/stores/*.js",
      "types": "./dist/stores/*.d.ts"
    },
    "./hooks/*": {
      "import": "./dist/hooks/*.mjs",
      "require": "./dist/hooks/*.js",
      "types": "./dist/hooks/*.d.ts"
    },
    "./types/*": {
      "import": "./dist/types/*.mjs",
      "require": "./dist/types/*.js",
      "types": "./dist/types/*.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "test:unit": "vitest run --exclude '**/*.integration.test.ts'",
    "test:integration": "vitest run --testPathPattern 'integration'",
    "test:e2e": "vitest run --testPathPattern 'flows'",
    "test:watch": "vitest",
    "test:health": "vitest run --testPathPattern 'healthCheck'"
  },
  "dependencies": {
    "bignumber.js": "^9.3.1",
    "ethers": "^6.14.1",
    "matrix-js-sdk": "^39.0.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/react": "^19.0.2",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.0.2",
    "web-vitals": "^4.2.4"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  }
}
