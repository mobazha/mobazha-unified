{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./",
    "baseUrl": ".",
    "incremental": false,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "services/**/*",
    "stores/**/*",
    "hooks/**/*",
    "types/**/*",
    "utils/**/*",
    "providers/**/*",
    "config/**/*",
    "edition/**/*",
    "index.ts"
  ],
  "exclude": ["node_modules", "dist", "__tests__"]
}
