{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "../",
    "baseUrl": ".",
    "incremental": false,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./*"],
      "@mobazha/commerce-kit": ["../commerce-kit/src/index.ts"],
      "@mobazha/commerce-kit/*": ["../commerce-kit/src/*"]
    }
  },
  "include": [
    "services/**/*",
    "stores/**/*",
    "hooks/**/*",
    "types/**/*",
    "utils/**/*",
    "providers/**/*",
    "config/**/*",
    "index.ts"
  ],
  "exclude": ["node_modules", "dist", "__tests__"]
}
